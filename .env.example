# EmailJS Configuration
# Get these values from https://www.emailjs.com (free account)
# Steps:
#   1. Sign up at emailjs.com
#   2. Add Gmail service → "Email Services" → Connect Gmail
#   3. Create a template → "Email Templates"
#      Template should use variables: {{from_name}}, {{from_email}}, {{subject}}, {{message}}
#      Set "To Email" to your Gmail address
#   4. Go to Account → copy your Public Key
#   5. Fill in the values below and save this file as .env

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
